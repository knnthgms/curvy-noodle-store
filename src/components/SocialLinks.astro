---
import { SITE } from '@config';
import { whatsappChatLink } from '@utils/whatsapp';

/** Icon links to social profiles and WhatsApp. */
const links = [
  {
    label: 'Instagram',
    href: SITE.socials.instagram,
    path: 'M12 2.2c3.2 0 3.6 0 4.8.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.81 0 3.17-.01 3.54-.07 4.81-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.81.07-3.17 0-3.54-.01-4.81-.07-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.64-.07-4.81 0-3.16.01-3.54.07-4.81.15-3.23 1.66-4.77 4.92-4.92C8.4 2.21 8.77 2.2 12 2.2Zm0 3.64a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.4-9.85a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0Z',
  },
  {
    label: 'YouTube',
    href: SITE.socials.youtube,
    path: 'M23.5 6.2a3 3 0 0 0-2.1-2.12C19.54 3.5 12 3.5 12 3.5s-7.54 0-9.4.58A3 3 0 0 0 .5 6.2 31.2 31.2 0 0 0 0 12a31.2 31.2 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.12c1.86.58 9.4.58 9.4.58s7.54 0 9.4-.58a3 3 0 0 0 2.1-2.12A31.2 31.2 0 0 0 24 12a31.2 31.2 0 0 0-.5-5.8ZM9.6 15.6V8.4L15.84 12 9.6 15.6Z',
  },
  {
    label: 'WhatsApp',
    href: whatsappChatLink(),
    path: 'M12 2a9.94 9.94 0 0 0-8.59 14.96L2 22l5.18-1.36A9.96 9.96 0 1 0 12 2Zm0 18.13a8.1 8.1 0 0 1-4.13-1.13l-.3-.18-3.07.8.82-3-.2-.3a8.13 8.13 0 1 1 6.88 3.81Zm4.46-6.08c-.24-.12-1.44-.71-1.66-.8-.22-.08-.39-.12-.55.13-.16.24-.63.79-.77.95-.14.16-.28.18-.53.06a6.66 6.66 0 0 1-3.31-2.89c-.25-.43.25-.4.71-1.33.08-.16.04-.3-.02-.42-.06-.12-.55-1.32-.75-1.81-.2-.48-.4-.4-.55-.41h-.47c-.16 0-.43.06-.65.3-.22.24-.85.83-.85 2.03s.87 2.36 1 2.52c.12.16 1.72 2.62 4.16 3.68.58.25 1.04.4 1.39.51.59.19 1.12.16 1.54.1.47-.07 1.44-.59 1.65-1.16.2-.57.2-1.06.14-1.16-.06-.1-.22-.16-.46-.28Z',
  },
] as const;
---

<ul class="flex items-center gap-3">
  {
    links.map((link) => (
      <li>
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-cream-dark text-ink transition hover:bg-noodle"
        >
          <span class="sr-only">{link.label}</span>
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
            <path d={link.path} />
          </svg>
        </a>
      </li>
    ))
  }
</ul>
