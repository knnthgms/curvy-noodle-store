---
import { NAV_LINKS, SITE } from '@config';
import SocialLinks from '@components/SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="border-t-2 border-cream-dark bg-cream-dark/60">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="flex flex-col gap-8 sm:flex-row sm:justify-between">
      <div class="max-w-sm">
        <p class="font-display text-xl font-bold">{SITE.name}</p>
        <p class="mt-2 text-ink-soft">{SITE.tagline}</p>
        <div class="mt-4">
          <SocialLinks />
        </div>
      </div>

      <nav aria-label="Footer">
        <h2 class="font-display font-bold">Explore</h2>
        <ul class="mt-3 space-y-2">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a href={link.href} class="text-ink-soft underline-offset-4 hover:text-pink-deep hover:underline">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Legal">
        <h2 class="font-display font-bold">The boring bits</h2>
        <ul class="mt-3 space-y-2">
          <li>
            <a href="/privacy" class="text-ink-soft underline-offset-4 hover:text-pink-deep hover:underline">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/terms" class="text-ink-soft underline-offset-4 hover:text-pink-deep hover:underline">
              Terms of Service
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <p class="mt-10 border-t border-ink/10 pt-6 text-center text-sm text-ink-soft">
      © {year} {SITE.name}. Made with noodles, glue and love. 🍜
    </p>
  </div>
</footer>
