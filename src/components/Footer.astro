---
import { SITE } from '@config';

const year = new Date().getFullYear();
---

<footer class="border-t-2 border-cream-dark bg-cream-dark/60">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-3 px-4 py-8 text-center text-sm text-ink-soft sm:px-6">
    <p>© {year} {SITE.name} store</p>
    {/* Small legal links kept for practicality — safe to remove if you prefer. */}
    <p class="flex gap-4">
      <a href="/privacy" class="underline-offset-4 hover:text-pink-deep hover:underline">Privacy</a>
      <a href="/terms" class="underline-offset-4 hover:text-pink-deep hover:underline">Terms</a>
    </p>
  </div>
</footer>
