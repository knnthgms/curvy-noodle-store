---
/**
 * Newsletter signup placeholder. There is no mailing-list backend yet —
 * the form shows a friendly "coming soon" message on submit. Swap the
 * handler for a real provider (Buttondown, Mailchimp, …) when ready.
 */
---

<section class="mx-auto max-w-6xl px-4 sm:px-6" aria-labelledby="newsletter-heading">
  <div class="rounded-3xl bg-noodle px-6 py-10 text-center sm:px-12">
    <h2 id="newsletter-heading" class="font-display text-2xl font-bold sm:text-3xl">
      Join the noodle newsletter 💌
    </h2>
    <p class="mx-auto mt-2 max-w-md text-ink-soft">
      New sticker drops, special offers, and the occasional pun.
      No spam, only fun doodles.
    </p>
    <form id="newsletter-form" class="mx-auto mt-6 flex max-w-md flex-col gap-3 sm:flex-row" novalidate>
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        type="email"
        id="newsletter-email"
        name="email"
        required
        placeholder="you@example.com"
        autocomplete="email"
        class="w-full rounded-full border-2 border-ink/20 bg-white px-5 py-3 placeholder:text-ink-soft/70 focus:border-pink-deep focus:outline-none"
      />
      <button type="submit" class="btn-primary shrink-0">Sign up</button>
    </form>
    <p id="newsletter-status" role="status" class="mt-3 font-semibold text-pink-deep"></p>
  </div>
</section>

<script>
  const form = document.getElementById('newsletter-form');
  const status = document.getElementById('newsletter-status');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (status) {
      status.textContent =
        'The noodle letter is still simmering — follow me on Instagram in the meantime!';
    }
  });
</script>
