---
/**
 * Unified analytics head fragment.
 * Include once in BaseLayout — renders only when the matching env var is set.
 *
 * Cloudflare Web Analytics  →  PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN
 * Google Analytics 4        →  PUBLIC_GA_MEASUREMENT_ID
 * Microsoft Clarity          →  PUBLIC_CLARITY_PROJECT_ID
 */

const cfToken   = import.meta.env.PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN as string | undefined;
const gaId      = import.meta.env.PUBLIC_GA_MEASUREMENT_ID          as string | undefined;
const clarityId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID         as string | undefined;
---

{/* ── Cloudflare Web Analytics (cookie-free, privacy-friendly) ── */}
{cfToken && (
  <script
    is:inline
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon={`{"token":"${cfToken}"}`}
  />
)}

{/* ── Google Analytics 4 ── */}
{gaId && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
    <script
      is:inline
      set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}',{send_page_view:true});`}
    />
  </>
)}

{/* ── Microsoft Clarity (session recordings & heatmaps) ── */}
{clarityId && (
  <script
    is:inline
    set:html={`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","${clarityId}");`}
  />
)}
