---
import { formatDate, isoDate, readingTime } from '@utils/format';
import { postPath, type Post } from '@utils/collections';

/** Blog listing card with cover image, date, reading time and tags. */
interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, date, tags, coverImage, coverImageAlt } = post.data;
const href = postPath(post);
const minutes = readingTime(post.body ?? '');
---

<article class="group relative flex flex-col overflow-hidden rounded-3xl border-2 border-cream-dark bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md">
  <img
    src={coverImage}
    alt={coverImageAlt}
    width="800"
    height="450"
    loading="lazy"
    decoding="async"
    class="aspect-video w-full bg-cream object-cover"
  />
  <div class="flex flex-1 flex-col gap-2 p-5">
    <p class="text-sm text-ink-soft">
      <time datetime={isoDate(date)}>{formatDate(date)}</time>
      <span aria-hidden="true"> · </span>
      {minutes} min read
    </p>
    <h3 class="font-display text-xl font-bold">
      <a href={href} class="after:absolute after:inset-0">
        {title}
      </a>
    </h3>
    <p class="text-ink-soft">{description}</p>
    {
      tags.length > 0 && (
        <ul class="mt-auto flex flex-wrap gap-2 pt-2" aria-label="Tags">
          {tags.map((tag) => (
            <li class="chip">{tag}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>
