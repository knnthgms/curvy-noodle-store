---
import { SITE } from '@config';

/** Home page hero: brand name, tagline and primary calls to action. */
---

<section class="relative overflow-hidden">
  {/* Decorative pastel blobs */}
  <svg
    class="pointer-events-none absolute -left-24 -top-24 h-72 w-72 text-peach"
    viewBox="0 0 200 200"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M44 121c-18-30-4-72 30-86s76 2 88 34-6 70-40 82-60 0-78-30Z"></path>
  </svg>
  <svg
    class="pointer-events-none absolute -bottom-28 -right-20 h-80 w-80 text-sage"
    viewBox="0 0 200 200"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M58 38c30-18 70-8 86 22s4 70-28 86-72 2-86-30 0-60 28-78Z"></path>
  </svg>

  <div class="relative mx-auto max-w-6xl px-4 py-16 text-center sm:px-6 sm:py-24">
    <p class="font-display text-lg font-semibold text-pink-deep">🍜 Welcome to</p>
    <h1 class="mt-2 font-display text-4xl font-bold sm:text-6xl">
      {SITE.name}
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-ink-soft sm:text-xl">
      {SITE.tagline}
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a href="/shop" class="btn-primary">Browse stickers</a>
      <a href="/about" class="btn-secondary">Our story</a>
    </div>
  </div>
</section>
