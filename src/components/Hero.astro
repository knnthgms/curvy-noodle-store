---
import { SITE } from '@config';

/** Home page hero: full-width banner illustration with primary calls to action. */
---

<section class="relative overflow-hidden">
  {/* Decorative pastel blobs */}
  <svg
    class="pointer-events-none absolute -left-24 -top-24 h-72 w-72 text-blush"
    viewBox="0 0 200 200"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M44 121c-18-30-4-72 30-86s76 2 88 34-6 70-40 82-60 0-78-30Z"></path>
  </svg>
  <svg
    class="pointer-events-none absolute -bottom-28 -right-20 h-80 w-80 text-sky"
    viewBox="0 0 200 200"
    fill="currentColor"
    aria-hidden="true"
  >
    <path d="M58 38c30-18 70-8 86 22s4 70-28 86-72 2-86-30 0-60 28-78Z"></path>
  </svg>

  <div class="relative mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-16">
    {/* Accessible page heading for SEO; the banner carries the visible headline */}
    <h1 class="sr-only">{SITE.name} — {SITE.tagline}</h1>

    <img
      src="/images/branding/homepage-banner.svg"
      alt={`${SITE.name} — Stickers that get you. Real moods. Real days. Made for planners everywhere.`}
      width="1600"
      height="480"
      class="mx-auto w-full rounded-3xl shadow-sm"
      loading="eager"
      decoding="async"
    />

    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a href="/shop" class="btn-primary">Browse the store</a>
      <a href="/about" class="btn-secondary">My story</a>
    </div>
  </div>
</section>
