---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config';
---

<BaseLayout
  title="Privacy Policy"
  description="How The Curvy Noodle Shop handles your information."
>
  <div class="prose mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1>Privacy Policy</h1>
    <p><em>Last updated: June 2026 — placeholder text, review before launch.</em></p>

    <h2>The short version</h2>
    <p>
      This is a static website. We don't run accounts, shopping carts or
      trackers that follow you around the internet.
    </p>

    <h2>What we collect</h2>
    <ul>
      <li>
        <strong>Orders:</strong> placed over WhatsApp, so your messages are
        handled by WhatsApp under their own privacy policy. We only see what
        you send us (name, address, order details) and use it solely to
        fulfil your order.
      </li>
      <li>
        <strong>Analytics:</strong> we may use privacy-friendly, cookie-free
        analytics (Cloudflare Web Analytics) to count visits. If Google
        Analytics is enabled, it is noted here and used only in aggregate.
      </li>
    </ul>

    <h2>What we don't do</h2>
    <ul>
      <li>We don't sell or share your information with third parties.</li>
      <li>We don't send marketing messages without your consent.</li>
      <li>We don't store payment details — payments are arranged directly over WhatsApp.</li>
    </ul>

    <h2>Questions?</h2>
    <p>
      Email us at <a href={`mailto:${SITE.email}`}>{SITE.email}</a> and a
      real human will reply.
    </p>
  </div>
</BaseLayout>
