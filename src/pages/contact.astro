---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import { SITE } from '@config';
import { breadcrumbSchema } from '@utils/schema';

const breadcrumbs = [{ label: 'Home', href: '/' }, { label: 'Contact' }];
---

<BaseLayout
  title="Contact"
  description="Questions, custom sticker ideas or just want to say hi? Reach The Curvy Noodle Shop on WhatsApp, Instagram or through the contact form."
  schemas={[breadcrumbSchema(breadcrumbs)]}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="mt-4 font-display text-4xl font-bold">Say hello 💬</h1>
    <p class="mt-2 max-w-2xl text-lg text-ink-soft">
      Questions about an order, a custom sticker idea, or just want to share
      a photo of where your noodle ended up? We'd love to hear from you.
    </p>

    <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-2">
      {/* Contact form (UI only — no backend wired up yet) */}
      <form id="contact-form" class="rounded-3xl border-2 border-cream-dark bg-white p-6 sm:p-8" novalidate>
        <h2 class="font-display text-2xl font-bold">Send a note</h2>

        <div class="mt-6 space-y-5">
          <div>
            <label for="contact-name" class="block font-display font-semibold">Your name</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
              class="mt-1 w-full rounded-2xl border-2 border-cream-dark px-4 py-3 focus:border-pink-deep focus:outline-none"
            />
          </div>
          <div>
            <label for="contact-email" class="block font-display font-semibold">Email</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
              class="mt-1 w-full rounded-2xl border-2 border-cream-dark px-4 py-3 focus:border-pink-deep focus:outline-none"
            />
          </div>
          <div>
            <label for="contact-message" class="block font-display font-semibold">Message</label>
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              class="mt-1 w-full rounded-2xl border-2 border-cream-dark px-4 py-3 focus:border-pink-deep focus:outline-none"
            ></textarea>
          </div>
          <button type="submit" class="btn-primary w-full sm:w-auto">Send message</button>
          <p id="contact-status" role="status" class="font-semibold text-pink-deep"></p>
          <p class="text-sm text-ink-soft">
            This form isn't wired to a mailbox yet — for now, WhatsApp is the
            fastest way to reach us.
          </p>
        </div>
      </form>

      {/* Other channels */}
      <div class="space-y-6">
        <div class="rounded-3xl bg-sage p-6 sm:p-8">
          <h2 class="font-display text-2xl font-bold text-sage-deep">WhatsApp (fastest!)</h2>
          <p class="mt-2 text-sage-deep">
            Orders, questions, custom requests — we usually reply within a day.
          </p>
          <div class="mt-4">
            <WhatsAppButton />
          </div>
        </div>

        <div class="rounded-3xl bg-peach p-6 sm:p-8">
          <h2 class="font-display text-2xl font-bold text-peach-deep">Instagram</h2>
          <p class="mt-2 text-peach-deep">
            Sneak peeks, works-in-progress and sticker giveaways.
          </p>
          <a
            href={SITE.socials.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary mt-4"
          >
            @thecurvynoodleshop
          </a>
        </div>

        <div class="rounded-3xl bg-noodle p-6 sm:p-8">
          <h2 class="font-display text-2xl font-bold text-noodle-deep">Email</h2>
          <p class="mt-2 text-noodle-deep">For wholesale and collaborations.</p>
          <a
            href={`mailto:${SITE.email}`}
            class="mt-2 inline-block font-display font-bold text-ink underline underline-offset-4"
          >
            {SITE.email}
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // Placeholder handler — swap for a real form backend when ready.
  const form = document.getElementById('contact-form');
  const status = document.getElementById('contact-status');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (status) {
      status.textContent =
        'The form is still under construction — please ping us on WhatsApp instead! 💚';
    }
  });
</script>
