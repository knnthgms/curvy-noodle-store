---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config';
---

<BaseLayout
  title="Terms of Service"
  description="Terms of service for The Curvy Noodle Shop."
>
  <div class="prose mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1>Terms of Service</h1>
    <p><em>Last updated: June 2026 — placeholder text, review before launch.</em></p>

    <h2>Orders</h2>
    <p>
      Orders are placed via WhatsApp and confirmed once we agree on items,
      price and delivery. Prices shown on the site are in Indian Rupees and
      may change without notice until an order is confirmed.
    </p>

    <h2>Shipping &amp; returns</h2>
    <p>
      We ship throughout India. Orders are dispatched within 2–3 business
      days and delivered within 5–8 business days depending on location, with
      tracking provided. Shipping is free on orders above ₹500.
    </p>
    <p>
      Due to the handmade nature of the products, opened or used products
      cannot be returned. If your order arrives damaged or incorrect, contact
      us within 48 hours of delivery with a photo and we'll make it right
      with a replacement or refund. See the <a href="/faq">FAQs</a> for full
      details.
    </p>

    <h2>Artwork</h2>
    <p>
      All designs are original artwork of {SITE.name}. Please don't
      reproduce, resell or mass-produce them. Sticking them on everything
      you own, however, is highly encouraged.
    </p>

    <h2>Contact</h2>
    <p>
      Questions about these terms? Email
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
    </p>
  </div>
</BaseLayout>
