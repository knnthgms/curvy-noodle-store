---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ProductCard from '@components/ProductCard.astro';
import SearchBar from '@components/SearchBar.astro';
import { CATEGORIES } from '@config';
import { getProducts } from '@utils/collections';
import { breadcrumbSchema } from '@utils/schema';

const products = await getProducts();
const breadcrumbs = [{ label: 'Home', href: '/' }, { label: 'Shop' }];
---

<BaseLayout
  title="Shop"
  description="Browse all Curvy Noodle Shop stickers — cute, waterproof, hand-drawn designs for journals, laptops and water bottles. Order over WhatsApp."
  schemas={[breadcrumbSchema(breadcrumbs)]}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="mt-4 font-display text-4xl font-bold">The sticker shop 🛒</h1>
    <p class="mt-2 max-w-2xl text-lg text-ink-soft">
      Every design is hand-drawn and printed on sturdy waterproof vinyl.
      Found a favourite? Tap it and order straight over WhatsApp.
    </p>

    {/* Search + category filters (client-side, no page reloads) */}
    <div class="mt-8 flex flex-col gap-4">
      <SearchBar id="shop-search" label="Search stickers" placeholder="Search stickers…" />
      <div role="group" aria-label="Filter by category" class="flex flex-wrap gap-2">
        <button type="button" class="filter-btn" data-filter="all" aria-pressed="true">
          All
        </button>
        {
          CATEGORIES.map((category) => (
            <button type="button" class="filter-btn" data-filter={category.slug} aria-pressed="false">
              {category.label}
            </button>
          ))
        }
      </div>
    </div>

    <div id="product-grid" class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((product, index) => <ProductCard product={product} eager={index < 3} />)}
    </div>

    <p id="no-results" role="status" class="mt-12 hidden text-center text-lg text-ink-soft">
      No stickers match your search — try another word, or
      <a href="/contact" class="font-semibold text-pink-deep underline underline-offset-4">
        ask us to draw it</a
      >! 🎨
    </p>
  </div>
</BaseLayout>

<style>
  .filter-btn {
    border: 2px solid var(--color-cream-dark);
    border-radius: 9999px;
    background: white;
    padding: 0.5rem 1rem;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-ink);
    transition: background-color 150ms;
  }
  .filter-btn:hover {
    background: var(--color-noodle);
  }
  .filter-btn[aria-pressed='true'] {
    border-color: var(--color-pink-deep);
    background: var(--color-pink);
    color: var(--color-pink-deep);
  }
</style>

<script>
  // Combined text search + category filtering over the product grid.
  const input = document.getElementById('shop-search') as HTMLInputElement | null;
  const buttons = [...document.querySelectorAll<HTMLButtonElement>('.filter-btn')];
  const cards = [...document.querySelectorAll<HTMLElement>('[data-product-card]')];
  const noResults = document.getElementById('no-results');

  let activeCategory = 'all';

  const applyFilters = (): void => {
    const query = (input?.value ?? '').trim().toLowerCase();
    let visible = 0;

    for (const card of cards) {
      const matchesCategory =
        activeCategory === 'all' || card.dataset.category === activeCategory;
      const matchesQuery =
        query === '' || (card.dataset.search ?? '').includes(query);
      const show = matchesCategory && matchesQuery;
      card.classList.toggle('hidden', !show);
      if (show) visible += 1;
    }

    noResults?.classList.toggle('hidden', visible > 0);
  };

  input?.addEventListener('input', applyFilters);

  for (const button of buttons) {
    button.addEventListener('click', () => {
      activeCategory = button.dataset.filter ?? 'all';
      for (const other of buttons) {
        other.setAttribute('aria-pressed', String(other === button));
      }
      applyFilters();
    });
  }
</script>
