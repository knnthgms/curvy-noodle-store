---
import { render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ProductCard from '@components/ProductCard.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import ProductGallery from '@components/ProductGallery.astro';
import { categoryLabel } from '@config';
import {
  getProducts,
  productPath,
  productSlug,
  relatedProducts,
  type Product,
} from '@utils/collections';
import { formatPrice } from '@utils/format';
import { breadcrumbSchema, productSchema } from '@utils/schema';

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((product) => ({
    params: { slug: productSlug(product) },
    props: { product, products },
  }));
}

interface Props {
  product: Product;
  products: Product[];
}

const { product, products } = Astro.props;
const { Content } = await render(product);
const {
  title,
  description,
  price,
  compareAtPrice,
  category,
  tags,
  image,
  imageAlt,
  gallery,
  dimensions,
  material,
} = product.data;

const related = relatedProducts(product, products);
const path = productPath(product);

// gallery is the authoritative image list; image/imageAlt are kept for OG tags and schema.
const galleryImages = gallery.length > 0
  ? gallery.map((g) => ({ src: g.src, alt: g.alt }))
  : [{ src: image, alt: imageAlt }];

// Percentage saved when the product is on sale (for the savings badge).
const percentOff = compareAtPrice
  ? Math.round((1 - price / compareAtPrice) * 100)
  : 0;

// Trust signals shown under the price — reassurances, not invented claims.
const trustSignals = [
  { icon: '🇮🇳', text: 'Handmade in India' },
  { icon: '🚚', text: 'Free shipping over ₹500' },
  { icon: '✍️', text: 'Matte — write right over it' },
  { icon: '📦', text: 'Ships in 2–3 days' },
];

// How ordering works, since there's no cart — sets expectations clearly.
const orderSteps = [
  'Tap “Order on WhatsApp” — it opens a chat with your sticker pre-filled.',
  'Confirm your sheets, quantity and delivery address with me.',
  'Pay, and I hand-pack and post your order across India. 🍜',
];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Store', href: '/shop' },
  { label: title },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  productSchema({ name: title, description, image, price, url: path, material }),
];
---

<BaseLayout title={title} description={description} ogImage={image} ogType="product" schemas={schemas}>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={breadcrumbs} />

    <div class="mt-6 grid grid-cols-1 gap-10 lg:grid-cols-2">
      {/* Gallery */}
      <ProductGallery images={galleryImages} productId={productSlug(product)} />

      {/* Details */}
      <div>
        <a href={`/collections/${category}/`} class="chip transition hover:bg-noodle">
          {categoryLabel(category)}
        </a>
        <h1 class="mt-3 font-display text-4xl font-bold">{title}</h1>

        <p class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1">
          <span class="font-display text-3xl font-bold text-pink-deep">{formatPrice(price)}</span>
          {
            compareAtPrice && (
              <>
                <s class="text-xl font-semibold text-ink-soft">
                  <span class="sr-only">Original price </span>
                  {formatPrice(compareAtPrice)}
                </s>
                <span class="rounded-full bg-pink-deep px-3 py-1 text-sm font-bold text-white">
                  Save {percentOff}%
                </span>
              </>
            )
          }
        </p>
        <p class="mt-1 text-sm font-semibold text-sky-deep">✓ In stock</p>

        <p class="mt-4 text-lg text-ink-soft">{description}</p>

        {/* Trust signals */}
        <ul class="mt-6 grid grid-cols-2 gap-2 text-sm font-semibold">
          {
            trustSignals.map((signal) => (
              <li class="flex items-center gap-2">
                <span aria-hidden="true">{signal.icon}</span>
                {signal.text}
              </li>
            ))
          }
        </ul>

        <div class="mt-8">
          <WhatsAppButton productName={title} size="lg" source={`product:${productSlug(product)}`} />
          <p class="mt-2 text-sm text-ink-soft">
            Opens WhatsApp with your order pre-filled — we reply within a day. 💬
          </p>
        </div>

        {/* How ordering works (no cart) */}
        <div class="mt-6 rounded-3xl bg-sky/60 p-5">
          <h2 class="font-display font-bold text-sky-deep">How ordering works</h2>
          <ol class="mt-2 list-decimal space-y-1 pl-5 text-sm text-sky-deep">
            {orderSteps.map((step) => <li>{step}</li>)}
          </ol>
        </div>

        <dl class="mt-8 grid grid-cols-1 gap-4 rounded-3xl bg-cream-dark/60 p-6 sm:grid-cols-2">
          <div>
            <dt class="font-display font-bold">Dimensions</dt>
            <dd class="text-ink-soft">{dimensions}</dd>
          </div>
          <div>
            <dt class="font-display font-bold">Material</dt>
            <dd class="text-ink-soft">{material}</dd>
          </div>
          {
            tags.length > 0 && (
              <div class="sm:col-span-2">
                <dt class="font-display font-bold">Tags</dt>
                <dd>
                  <ul class="mt-1 flex flex-wrap gap-2">
                    {tags.map((tag) => (
                      <li class="chip">{tag}</li>
                    ))}
                  </ul>
                </dd>
              </div>
            )
          }
        </dl>

        <div class="prose mt-8 max-w-none">
          <Content />
        </div>

        <p class="mt-6 text-sm text-ink-soft">
          Ships across India in 2–3 business days. Damaged or incorrect order?
          I'll replace or refund it — see the
          <a href="/faq" class="font-semibold text-pink-deep underline underline-offset-4">FAQs</a>
          for shipping &amp; returns details.
        </p>
      </div>
    </div>

    {/* Related products */}
    {
      related.length > 0 && (
        <section class="mt-16" aria-labelledby="related-heading">
          <h2 id="related-heading" class="font-display text-3xl font-bold">
            You might also like 💕
          </h2>
          <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((item) => (
              <ProductCard product={item} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>

<div
  id="product-analytics-data"
  data-item-id={productSlug(product)}
  data-item-name={title}
  data-price={price}
  data-category={category}
  hidden
/>

<script>
  import { trackViewItem } from '@utils/analytics';

  const meta = document.getElementById('product-analytics-data') as HTMLElement;
  if (meta) {
    trackViewItem({
      item_id: meta.dataset.itemId!,
      item_name: meta.dataset.itemName!,
      price: Number(meta.dataset.price),
      item_category: meta.dataset.category,
    });
  }
</script>
