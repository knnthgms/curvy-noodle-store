---
import { render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ProductCard from '@components/ProductCard.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import { categoryLabel } from '@config';
import {
  getProducts,
  productPath,
  productSlug,
  relatedProducts,
  type Product,
} from '@utils/collections';
import { formatPrice } from '@utils/format';
import { breadcrumbSchema, productSchema } from '@utils/schema';

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((product) => ({
    params: { slug: productSlug(product) },
    props: { product, products },
  }));
}

interface Props {
  product: Product;
  products: Product[];
}

const { product, products } = Astro.props;
const { Content } = await render(product);
const {
  title,
  description,
  price,
  category,
  tags,
  image,
  imageAlt,
  gallery,
  dimensions,
  material,
} = product.data;

const related = relatedProducts(product, products);
const path = productPath(product);

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Shop', href: '/shop' },
  { label: title },
];

const schemas = [
  breadcrumbSchema(breadcrumbs),
  productSchema({ name: title, description, image, price, url: path, material }),
];
---

<BaseLayout title={title} description={description} ogImage={image} ogType="product" schemas={schemas}>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={breadcrumbs} />

    <div class="mt-6 grid grid-cols-1 gap-10 lg:grid-cols-2">
      {/* Gallery */}
      <div>
        <img
          id="gallery-main"
          src={image}
          alt={imageAlt}
          width="800"
          height="800"
          decoding="async"
          class="aspect-square w-full rounded-3xl border-2 border-cream-dark bg-white object-cover"
        />
        {
          gallery.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-3" role="group" aria-label="More photos">
              {[{ src: image, alt: imageAlt }, ...gallery].map((item) => (
                <button
                  type="button"
                  class="gallery-thumb overflow-hidden rounded-2xl border-2 border-cream-dark transition hover:border-pink-deep"
                  data-src={item.src}
                  data-alt={item.alt}
                >
                  <img
                    src={item.src}
                    alt={item.alt}
                    width="96"
                    height="96"
                    loading="lazy"
                    decoding="async"
                    class="h-24 w-24 bg-white object-cover"
                  />
                </button>
              ))}
            </div>
          )
        }
      </div>

      {/* Details */}
      <div>
        <span class="chip">{categoryLabel(category)}</span>
        <h1 class="mt-3 font-display text-4xl font-bold">{title}</h1>
        <p class="mt-2 font-display text-3xl font-bold text-pink-deep">{formatPrice(price)}</p>
        <p class="mt-4 text-lg text-ink-soft">{description}</p>

        <div class="mt-8">
          <WhatsAppButton productName={title} size="lg" />
          <p class="mt-2 text-sm text-ink-soft">
            Opens WhatsApp with your order pre-filled — we reply within a day. 💬
          </p>
        </div>

        <dl class="mt-8 grid grid-cols-1 gap-4 rounded-3xl bg-cream-dark/60 p-6 sm:grid-cols-2">
          <div>
            <dt class="font-display font-bold">Dimensions</dt>
            <dd class="text-ink-soft">{dimensions}</dd>
          </div>
          <div>
            <dt class="font-display font-bold">Material</dt>
            <dd class="text-ink-soft">{material}</dd>
          </div>
          {
            tags.length > 0 && (
              <div class="sm:col-span-2">
                <dt class="font-display font-bold">Tags</dt>
                <dd>
                  <ul class="mt-1 flex flex-wrap gap-2">
                    {tags.map((tag) => (
                      <li class="chip">{tag}</li>
                    ))}
                  </ul>
                </dd>
              </div>
            )
          }
        </dl>

        <div class="prose mt-8 max-w-none">
          <Content />
        </div>
      </div>
    </div>

    {/* Related products */}
    {
      related.length > 0 && (
        <section class="mt-16" aria-labelledby="related-heading">
          <h2 id="related-heading" class="font-display text-3xl font-bold">
            You might also like 💕
          </h2>
          <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((item) => (
              <ProductCard product={item} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>

<script>
  // Swap the main gallery image when a thumbnail is clicked.
  const main = document.getElementById('gallery-main') as HTMLImageElement | null;
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.gallery-thumb');

  thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      if (main && thumb.dataset.src) {
        main.src = thumb.dataset.src;
        main.alt = thumb.dataset.alt ?? '';
      }
    });
  });
</script>
