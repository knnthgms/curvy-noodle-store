---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { breadcrumbSchema } from '@utils/schema';

const breadcrumbs = [{ label: 'Home', href: '/' }, { label: 'About' }];

const processSteps = [
  {
    emoji: '✏️',
    title: 'Doodle',
    text: 'Every design starts as a pencil sketch in a well-loved sketchbook — usually over a bowl of actual noodles.',
  },
  {
    emoji: '🎨',
    title: 'Colour',
    text: 'Sketches are inked and painted digitally in our soft pastel palette, then fussed over until they feel just right.',
  },
  {
    emoji: '✂️',
    title: 'Print & cut',
    text: 'Stickers are printed in small batches on waterproof vinyl and kiss-cut by hand, so each one is checked before it ships.',
  },
];
---

<BaseLayout
  title="About"
  description="The story behind The Curvy Noodle Shop — a tiny independent sticker studio making playful, hand-drawn stickers in small batches."
  schemas={[breadcrumbSchema(breadcrumbs)]}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={breadcrumbs} />

    {/* Story */}
    <section class="mx-auto mt-6 max-w-3xl" aria-labelledby="story-heading">
      <h1 id="story-heading" class="font-display text-4xl font-bold sm:text-5xl">
        Hello, we're The Curvy Noodle Shop 👋
      </h1>
      <div class="mt-6 space-y-4 text-lg text-ink-soft">
        <p>
          It started with a doodle of a ramen bowl that came out a little…
          curvy. Instead of erasing it, we gave it a face. Then a friend
          asked for one as a sticker, then her friend did, and suddenly the
          kitchen table was a sticker studio.
        </p>
        <p>
          Today The Curvy Noodle Shop is still a one-desk operation. Every
          design begins as a hand-drawn sketch, every order is packed by the
          same two hands that drew it, and every envelope leaves with a tiny
          doodle on the back — because getting mail should feel like a gift.
        </p>
        <p>
          Our stickers live on journals, laptops, water bottles, fridges,
          guitar cases and at least one skateboard that we know of. Wherever
          yours end up, we hope they make you smile on ordinary days.
        </p>
      </div>
    </section>

    {/* Creative process */}
    <section class="mt-16" aria-labelledby="process-heading">
      <h2 id="process-heading" class="text-center font-display text-3xl font-bold">
        How a sticker is born
      </h2>
      <ol class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
        {
          processSteps.map((step, index) => (
            <li class="rounded-3xl border-2 border-cream-dark bg-white p-6 text-center">
              <span class="text-4xl" aria-hidden="true">
                {step.emoji}
              </span>
              <h3 class="mt-3 font-display text-xl font-bold">
                {index + 1}. {step.title}
              </h3>
              <p class="mt-2 text-ink-soft">{step.text}</p>
            </li>
          ))
        }
      </ol>
    </section>

    {/* Mission */}
    <section class="mt-16 rounded-3xl bg-sage px-6 py-12 text-center sm:px-12" aria-labelledby="mission-heading">
      <h2 id="mission-heading" class="font-display text-3xl font-bold text-sage-deep">Our mission</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-sage-deep">
        To sneak little moments of joy into everyday objects — one slightly
        wobbly, lovingly hand-drawn sticker at a time. Small-batch, kind to
        the planet where we can be, and never too serious.
      </p>
      <a href="/shop" class="btn-primary mt-6">Browse the stickers</a>
    </section>
  </div>
</BaseLayout>
