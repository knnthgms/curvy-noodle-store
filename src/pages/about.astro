---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { breadcrumbSchema } from '@utils/schema';

const breadcrumbs = [{ label: 'Home', href: '/' }, { label: 'About' }];

const processSteps = [
  {
    emoji: '✏️',
    title: 'Hand-illustrated',
    text: 'Every character starts as a hand-drawn illustration — covering real moods and real routines, from motivated mornings to tired evenings.',
  },
  {
    emoji: '✂️',
    title: 'Handmade',
    text: 'Each sheet is handmade on premium matte paper that resists smudging and lets you write directly over the stickers.',
  },
  {
    emoji: '📦',
    title: 'Packed personally',
    text: 'All orders are packaged personally, with care, from my little corner of India — and shipped across the country.',
  },
];
---

<BaseLayout
  title="About"
  description="The story behind Curvy Noodle — handmade planner stickers, hand-illustrated by one independent creator in India for bullet journals and daily planners."
  schemas={[breadcrumbSchema(breadcrumbs)]}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={breadcrumbs} />

    {/* TODO: Add about page illustrations */}

    {/* Story — original copy from curvynoodle.com/pages/about */}
    <section class="mx-auto mt-6 max-w-3xl" aria-labelledby="story-heading">
      <h1 id="story-heading" class="font-display text-4xl font-bold sm:text-5xl">
        About Curvy Noodle
      </h1>
      <div class="mt-6 space-y-4 text-lg text-ink-soft">
        <p>
          Hi, I'm Curvy Noodle — a lover of all things stationery, planning,
          and the tiny joys that make everyday life a little more colourful. 🍜
        </p>
        <p>
          This store started the way most passion projects do — out of a
          personal need. I'd been bullet journaling and regular planning for
          years and kept searching for planner stickers that felt
          <em>personal</em> — characters that actually looked like they were
          having a real day, with real moods and real routines. I couldn't
          find quite what I wanted, so I made them myself.
        </p>
        <p>
          What began as stickers for my own planner slowly turned into
          something I wanted to share. Every sheet in the Curvy Noodle range
          is hand-illustrated and handmade by me, packed with characters that
          cover the full spectrum of a real human week — the motivated
          mornings, the tired evenings, the everything-went-wrong Tuesdays,
          and the quietly lovely Sundays.
        </p>
        <p>
          All orders are packaged personally, with care, from my little
          corner of India. When you order from Curvy Noodle, you're
          supporting an independent creator — and that means the world to me.
        </p>
        <p>
          I hope these stickers bring as much joy to your planner as they
          bring to mine. Happy planning! 🌸
        </p>
        <p class="font-hand text-3xl text-pink-deep">— Curvy Noodle</p>
      </div>
    </section>

    {/* Creative process */}
    <section class="mt-16" aria-labelledby="process-heading">
      <h2 id="process-heading" class="text-center font-display text-3xl font-bold">
        How every sheet is made
      </h2>
      <ol class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
        {
          processSteps.map((step, index) => (
            <li class="rounded-3xl border-2 border-cream-dark bg-white p-6 text-center">
              <span class="text-4xl" aria-hidden="true">
                {step.emoji}
              </span>
              <h3 class="mt-3 font-display text-xl font-bold">
                {index + 1}. {step.title}
              </h3>
              <p class="mt-2 text-ink-soft">{step.text}</p>
            </li>
          ))
        }
      </ol>
    </section>

    {/* Mission */}
    <section class="mt-16 rounded-3xl bg-sky px-6 py-12 text-center sm:px-12" aria-labelledby="mission-heading">
      <h2 id="mission-heading" class="font-display text-3xl font-bold text-sky-deep">Why Curvy Noodle exists</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-sky-deep">
        To make planner stickers that feel personal — characters having a
        real day, with real moods and real routines — so that planning your
        week feels like a tiny joy instead of a chore.
      </p>
      <a href="/shop" class="btn-primary mt-6">Browse the store</a>
    </section>
  </div>
</BaseLayout>
