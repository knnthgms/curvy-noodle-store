---
import '@fontsource/lilita-one';
import '@fontsource-variable/noto-sans';
import '@fontsource-variable/caveat';
import '../styles/global.css';
import SEO from '@components/SEO.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import StickyWhatsApp from '@components/StickyWhatsApp.astro';
import Analytics from '@components/Analytics.astro';
import { SITE } from '@config';
import { organizationSchema, websiteSchema } from '@utils/schema';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'product';
  canonical?: string;
  noindex?: boolean;
  schemas?: Record<string, unknown>[];
}

const { schemas = [], ...seo } = Astro.props;

// Organization + WebSite schema ship on every page; pages append their own.
const allSchemas = [organizationSchema(), websiteSchema(), ...schemas];
---

<!doctype html>
<html lang={SITE.locale} data-theme={SITE.theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#fffbf4" />
    <SEO {...seo} schemas={allSchemas} />
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-pink-deep focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to main content
    </a>

    <Header />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    <StickyWhatsApp />
  </body>
</html>
