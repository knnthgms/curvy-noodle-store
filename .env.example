# Copy to `.env` for local development, or set these in the
# Cloudflare Pages dashboard (Settings → Environment variables).

# Canonical production URL (used for sitemap, canonical tags, structured data).
SITE_URL=https://thecurvynoodleshop.com

# --- Analytics (all optional — leave empty to disable) ---

# Cloudflare Web Analytics beacon token.
# Dashboard → Analytics & Logs → Web Analytics → your site → token.
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity project ID (found in Settings → Overview).
PUBLIC_CLARITY_PROJECT_ID=

# Web3Forms access keys — create one per form at https://web3forms.com
PUBLIC_WEB3FORMS_CONTACT_KEY=
PUBLIC_WEB3FORMS_NEWSLETTER_KEY=
